<Window x:Class="Task_Flyout.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Task_Flyout"
        x:Name="RootWindow"  Title="FlyoutWindow" Height="650" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        Deactivated="Window_Deactivated"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:EventMarkerConverter x:Key="EventMarkerConverter"/>

        <Style x:Key="MyDayStyle" TargetType="CalendarDayButton">
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Grid Width="34" Height="34" Margin="0,1">

                            <Border x:Name="BackgroundBorder" 
                                    CornerRadius="17" 
                                    Background="Transparent" 
                                    BorderThickness="1" 
                                    BorderBrush="Transparent"/>

                            <ContentPresenter x:Name="NormalText" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>

                            <Ellipse Width="4" Height="4" Fill="#999999" VerticalAlignment="Bottom" Margin="0,0,0,3" IsHitTestVisible="False">
                                <Ellipse.Visibility>
                                    <MultiBinding Converter="{StaticResource EventMarkerConverter}">
                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=CalendarDayButton}"/>
                                        <Binding ElementName="RootWindow" Path="MarkedDates"/>
                                    </MultiBinding>
                                </Ellipse.Visibility>
                            </Ellipse>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ApplicationBackgroundBrush}" CornerRadius="12" 
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.25" Direction="270" />
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtSelectedDate" Grid.Row="0" Text="今天, 日程安排" FontSize="18" FontWeight="SemiBold" 
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="4,0,0,12" />

            <Viewbox Grid.Row="1" Stretch="Uniform" Margin="0,8,0,16">
                <Calendar x:Name="MainCalendar" 
                          CalendarDayButtonStyle="{StaticResource MyDayStyle}" 
                          BorderThickness="0" 
                          Background="Transparent" 
                          SelectedDatesChanged="MainCalendar_SelectedDatesChanged"/>
            </Viewbox>

            <ui:Card Grid.Row="2" VerticalAlignment="Stretch" Padding="0">
                <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,8,0,8" PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
                    <ItemsControl x:Name="AgendaListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:CardAction Margin="8,0,8,8" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="4" Background="{DynamicResource SystemAccentColorPrimaryBrush}" CornerRadius="2" Margin="0,0,12,0"
                                                Visibility="{Binding IsEvent, Converter={StaticResource BoolToVis}}"/>

                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                  Margin="0,0,12,0" VerticalAlignment="Center"
                                                  Visibility="{Binding IsTask, Converter={StaticResource BoolToVis}}"
                                                  Click="TaskCheckBox_Click"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="14">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Title}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </ui:CardAction>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </ui:Card>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" Icon="{ui:SymbolIcon Settings24}" Appearance="Transparent" ToolTip="设置"/>
                <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Transparent" ToolTip="强制同步云端" Click="BtnRefresh_Click" Margin="4,0,0,0"/>

                <ui:Button Grid.Column="3" Icon="{ui:SymbolIcon Add24}" Content="添加任务" Appearance="Primary"/>
            </Grid>
        </Grid>
    </Border>
</Window>